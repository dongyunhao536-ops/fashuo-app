# 复制为 /opt/fashuo-app/.env.production 并填值。
# 别 commit 真值——.env* 已经在 .gitignore。

# ===== 鉴权 =====
# 必须改成一个真的口令；保留 change-me 就等于全站开放
APP_PASSWORD=

# ===== 七牛云 LLM =====
LLM_API_KEY=
LLM_BASE_URL=https://api.qnaigc.com
MODEL_ASK=anthropic/claude-4.8-opus
MODEL_DRAFT=anthropic/claude-4.7-opus
MODEL_GRADING=anthropic/claude-4.7-opus

# ===== 成本栅栏 =====
# 美元/天。$3 ≈ ¥22；月硬顶 ≈ ¥660
DAILY_BUDGET_USD=3

# ===== Supabase 兼容层（自托管 PostgREST）=====
# 在 ECS 上 = 通过 nginx 反代到 PostgREST :3001（绕一圈但 latency <5ms）
# 不要写成 http://127.0.0.1:3001 —— supabase-js 默认会拼 /rest/v1，与 nginx rewrite 对得上
NEXT_PUBLIC_SUPABASE_URL=https://<ECS-IP>:8443
# 04-mint-jwt.mjs 输出的两个 JWT
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===== 自签证书信任 =====
# ECS 端：pm2 已通过 NODE_EXTRA_CA_CERTS=/opt/fashuo-ca.crt 注入，**.env.production 不用配**
# PC 端 .env.local 上要加（npm run sync / register 用）：
#   NODE_EXTRA_CA_CERTS=path/to/fashuo-ca.crt   ← 把 CA 拷到 PC
# 或者懒省事：
#   NODE_TLS_REJECT_UNAUTHORIZED=0              ← 全局不验证证书（不推荐，但单用户能凑合）
